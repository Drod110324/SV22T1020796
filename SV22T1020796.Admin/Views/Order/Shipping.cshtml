@{
    Layout = null;
}
<div class="modal-dialog">
    <div class="modal-content">
        <form action="~/Order/Shipping/@ViewBag.OrderID" method="post">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">Xác nhận chuyển giao hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="control-label fw-bold">Người giao hàng:</label>
                    <select class="form-select" name="shipperID">
                        <option value="0">-- Chọn người giao hàng ---</option>
                        @foreach (var s in (await PartnerDataService.ListShippersAsync(new SV22T1020796.Models.Common.PaginationSearchInput { Page = 1, PageSize = 9999, SearchValue = "" })).DataItems)
                        {
                            <option value="@s.ShipperID">@s.ShipperName</option>
                        }
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-truck me-1"></i> Xác nhận giao hàng
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </form>
    </div>
</div>
