                $('input[name="email"]').addClass('is-invalid border-danger');
                isValid = false;
            } else if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
                $('#error-email').text('Email khÃīng ÄÃšng Äáŧnh dášĄng');
                $('input[name="email"]').addClass('is-invalid border-danger');
                isValid = false;
            }

            // Validate Táŧnh thÃ nh
            if (!$('select[name="province"]').val()) {
                $('#error-province').text('Vui lÃēng cháŧn Táŧnh/ThÃ nh pháŧ');
