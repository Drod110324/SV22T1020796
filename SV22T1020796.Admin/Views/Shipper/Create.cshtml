@model SV22T1020796.Models.Partner.Shipper
@{
    ViewBag.Title = "Thêm người giao hàng";
}
@section PageToolBar {
    <button type="submit" form="formCreate" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thông tin
    </button>
    <a href="~/Shipper" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0 fw-bold text-primary">
                    <i class="bi bi-truck me-2"></i>
                    Thông tin người giao hàng
                </h5>
            </div>

            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-circle me-1"></i>
                        <strong>Vui lòng kiểm tra lại dữ liệu:</strong>
                        <ul class="mb-0 mt-1">
                            @foreach (var state in ViewData.ModelState)
                            {
                                @foreach (var error in state.Value.Errors)
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <form id="formCreate" action="~/Shipper/Save" method="post">
                    <input type="hidden" name="ShipperID" value="@Model?.ShipperID" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên người giao hàng:</label>
                        <input type="text" class="form-control" name="ShipperName"
                               value="@Model?.ShipperName"
                               placeholder="VD: Viettel Post, Nguyễn Văn A..." autofocus required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Điện thoại:</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                            <input type="tel" class="form-control" name="Phone"
                                   value="@Model?.Phone"
                                   placeholder="Số điện thoại...">
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>