            $('.error-msg').text(''); // XÃģa cÃĄc thÃīng bÃĄo láŧi cÅĐ
            $('.form-control, .form-select').removeClass('is-invalid border-danger');

            var isValid = true;
            
            // Validate Háŧ tÃŠn
            if (!$('input[name="customerName"]').val() || !$('input[name="customerName"]').val().trim()) {
                $('#error-customerName').text('Vui lÃēng nháš­p háŧ tÃŠn ngÆ°áŧi nháš­n');
                $('input[name="customerName"]').addClass('is-invalid border-danger');
