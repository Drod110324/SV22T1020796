@model SV22T1020796.Models.Catalog.ProductSearchInput
@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <!-- Tìm kiếm & chọn mặt hàng -->
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <!-- Search Form -->
                <form id="formSearchProduct" action="~/Order/SearchProduct" method="get" class="mb-3">
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <div class="input-group">
                        <input type="text" 
                               name="searchValue" 
                               class="form-control" 
                               placeholder="Nhập tên mặt hàng cần tìm" 
                               autofocus 
                               value="@Model.SearchValue" />
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <!-- Danh sách mặt hàng (Partial View) -->
                <div id="searchProductResult" style="height: 600px; overflow-y: auto;">
                </div>
                <!-- Phân trang sản phẩm -->
                <div id="searchProductPagination" class="pt-2">
                </div>
            </div>
        </div>
    </div>

    <!-- Giỏ hàng và thông tin khách hàng -->
    <div class="col-8">
        <!-- Giỏ hàng (Partial View) -->
        <div class="row">
            <div class="col-12">
                <div class="card card-outline card-success">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-cart"></i>
                            Danh sách mặt hàng đã chọn
                        </h5>
                    </div>

                    <div class="card-body" id="showShoppingCart">
                    </div>
                </div>
            </div>
        </div>

        <!-- Thông tin khách hàng và nơi giao hàng -->
        <div class="row mt-3">
            <div class="col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person"></i>
                            Thông tin khách hàng & nơi giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        <form id="formInitOrder" action="~/Order/Init" method="post">
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Khách hàng</label>
                                <div class="col-md-10">
                                    <select name="customerName" class="form-select select2-tags">
                                        <option value="">-- Chọn khách hàng hoặc nhập tên mới --</option>
                                        @foreach (var c in (await PartnerDataService.ListCustomersAsync(new SV22T1020796.Models.Common.PaginationSearchInput { Page = 1, PageSize = 9999, SearchValue = "" })).DataItems)
                                        {
                                            <option value="@c.CustomerName">@c.CustomerName</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                                <div class="col-md-10">
                                    <select name="deliveryProvince" class="form-select select2">
                                        <option value="">-- Chọn Tỉnh/thành giao hàng --</option>
                                        @foreach (var p in await SV22T1020796.BusinessLayers.DictionaryDataService.ListProvincesAsync())
                                        {
                                            <option value="@p.ProvinceName">@p.ProvinceName</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Địa chỉ</label>
                                <div class="col-md-10">
                                    <textarea name="address" class="form-control" placeholder="Số nhà, tên đường, thôn/xóm..." rows="2"></textarea>
                                </div>
                            </div>

                            <div class="text-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i>
                                    Lập đơn hàng
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Khởi tạo Select2 cho các thẻ select (sử dụng jQuery như yêu cầu của Select2)
            $(".select2").select2({
                theme: "bootstrap-5",
                width: '100%',
                placeholder: $(this).data('placeholder'),
            });
            
            // Đặc biệt cho khách hàng: Cho phép nhập tên mới (tags)
            $(".select2-tags").select2({
                theme: "bootstrap-5",
                width: '100%',
                tags: true, // Cho phép nhập giá trị không có trong danh sách
                placeholder: "-- Chọn khách hàng hoặc nhập tên mới --",
                allowClear: true
            });

            // Hiển thị giỏ hàng và danh sách hàng hóa ban đầu
            doSearchProduct(@Model.Page);
            showShoppingCart();

            // Tìm kiếm hàng hóa
            const formSearchProduct = document.getElementById("formSearchProduct");
            if (formSearchProduct) {
                formSearchProduct.addEventListener("submit", function (e) {
                    e.preventDefault();
                    doSearchProduct(1);
                });
            }

            // Lập đơn hàng
            const formInitOrder = document.getElementById("formInitOrder");
            if (formInitOrder) {
                formInitOrder.addEventListener("submit", function (e) {
                    e.preventDefault();
                    const action = this.getAttribute("action");
                    const method = this.getAttribute("method") || "POST";
                    const formData = new FormData(this);

                    fetch(action, {
                        method: method,
                        body: formData
                    })
                    .then(res => res.json())
                    .then(result => {
                        if (result.success) {
                            Swal.fire({
                                title: 'Thành công!',
                                text: 'Đơn hàng đã được lập thành công.',
                                icon: 'success',
                                showConfirmButton: true,
                                confirmButtonText: 'Xem chi tiết đơn hàng',
                                confirmButtonColor: '#3085d6',
                                timer: 3000,
                                timerProgressBar: true
                            }).then((res) => {
                                window.location.href = "@Url.Content("~/Order/Detail/")" + result.orderID;
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Lỗi',
                                text: result,
                            });
                        }
                    })
                    .catch(err => {
                        console.error("Lỗi khi lập đơn hàng:", err);
                    });
                });
            }

            // Event delegation: Bắt sự kiện submit từ các form "Thêm vào giỏ" được nạp động
            document.getElementById("searchProductResult").addEventListener("submit", function (e) {
                const form = e.target.closest(".form-add-to-cart");
                if (!form) return;

                e.preventDefault();
                const action = form.getAttribute("action");
                const method = form.getAttribute("method") || "POST";
                const formData = new FormData(form);

                fetch(action, {
                    method: method,
                    body: formData
                })
                .then(res => res.json())
                .then(result => {
                    if (result !== "" && typeof result === "string") {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Thông báo',
                            text: result
                        });
                    } else {
                        showShoppingCart();
                        const Toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 2000,
                            timerProgressBar: true
                        });
                        Toast.fire({
                            icon: 'success',
                            title: 'Đã thêm vào giỏ hàng'
                        });
                    }
                })
                .catch(err => {
                    console.error("Lỗi khi thêm vào giỏ hàng:", err);
                });
            });
        });

        // Hàm tìm kiếm sản phẩm và hiển thị kết quả SearchProduct
        function doSearchProduct(page) {
            const url = "@Url.Content("~/Order/SearchProduct")";
            const formSearchProduct = document.getElementById("formSearchProduct");
            const formData = new FormData(formSearchProduct);
            formData.append("page", page);
            
            const params = new URLSearchParams(formData).toString();
            
            fetch(url + "?" + params)
                .then(res => res.text())
                .then(html => {
                    const tempDiv = document.createElement("div");
                    tempDiv.innerHTML = html;
                    
                    const pagination = tempDiv.querySelector("#paginationHolder");
                    const paginationTarget = document.getElementById("searchProductPagination");
                    
                    if (pagination && paginationTarget) {
                        paginationTarget.innerHTML = pagination.innerHTML;
                        pagination.remove(); // Xóa khỏi tempDiv để không bị lặp lại trong vùng cuộn
                    } else if (paginationTarget) {
                        paginationTarget.innerHTML = "";
                    }
                    
                    const resultTarget = document.getElementById("searchProductResult");
                    resultTarget.innerHTML = tempDiv.innerHTML;
                    resultTarget.scrollTop = 0; // Cuộn lên đầu khi sang trang mới
                    
                    // Khởi tạo AutoNumeric cho các ô tiền tệ mới được nạp động
                    resultTarget.querySelectorAll(".money-input").forEach(element => {
                        if (!AutoNumeric.getAutoNumericElement(element)) {
                            new AutoNumeric(element, {
                                digitGroupSeparator: '.',
                                decimalCharacter: ',',
                                decimalPlaces: 0,
                                unformatOnSubmit: true
                            });
                        }
                    });
                })
                .catch(err => {
                    console.error("Lỗi khi tìm kiếm sản phẩm:", err);
                });
        }

        // Hàm hiển thị giỏ hàng
        function showShoppingCart() {
            const url = "@Url.Action("ShowShoppingCart", "Order")";
            fetch(url)
                .then(res => res.text())
                .then(html => {
                    document.getElementById("showShoppingCart").innerHTML = html;
                })
                .catch(err => {
                    console.error("Lỗi khi hiển thị giỏ hàng:", err);
                });
        }

        // --- CÁC HÀM XỬ LÝ TRÊN GIỎ HÀNG (Dùng cho cả ShowShoppingCart partial) ---
        function updateCartItem(input) {
            const id = input.dataset.id;
            const qty = input.value;
            const price = input.dataset.price;
            
            if (qty <= 0) {
                input.value = 1;
                qty = 1;
            }

            const formData = new FormData();
            formData.append("id", id);
            formData.append("quantity", qty);
            formData.append("salePrice", price);

            fetch("@Url.Action("UpdateCartItem", "Order")", {
                method: "POST",
                body: formData
            })
            .then(res => res.json())
            .then(result => {
                 if (result !== "" && typeof result === "string") {
                      Swal.fire({
                          icon: 'error',
                          title: 'Lỗi',
                          text: result
                      });
                 } else {
                      showShoppingCart();
                 }
            })
            .catch(err => {
                console.error("Lỗi khi cập nhật giỏ hàng:", err);
            });
        }

        function removeFromCart(e, btn) {
            e.preventDefault();
            const url = btn.getAttribute("href");
            fetch(url)
            .then(() => {
                 showShoppingCart();
            })
            .catch(err => {
                console.error("Lỗi khi xóa khỏi giỏ hàng:", err);
            });
        }

        function clearCart(e, btn) {
            e.preventDefault();
            Swal.fire({
                title: 'Xóa giỏ hàng?',
                text: "Bạn có chắc chắn muốn xóa toàn bộ mặt hàng trong giỏ hàng?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Đồng ý xóa',
                cancelButtonText: 'Hủy bỏ'
            }).then((result) => {
                if (result.isConfirmed) {
                    const url = btn.getAttribute("href");
                    fetch(url)
                    .then(() => {
                         showShoppingCart();
                    })
                    .catch(err => {
                        console.error("Lỗi khi xóa giỏ hàng:", err);
                    });
                }
            });
        }
    </script>
}


