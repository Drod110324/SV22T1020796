@model SV22T1020796.Models.Partner.Customer
@{
    ViewBag.Title = "Bổ sung khách hàng";
}
@section PageToolBar {
    <button type="submit" form="formCreate" class="btn btn-primary">
        <i class="bi bi-save me-1"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Customer" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card card-primary card-outline shadow-sm">
    <div class="card-header">
        <h3 class="card-title fw-bold text-primary">
            <i class="bi bi-person-gear"></i> Thiết lập thông tin khách hàng
        </h3>
    </div>

    <form id="formCreate" action="~/Customer/Save" method="post">
        <input type="hidden" name="CustomerID" value="@Model?.CustomerID" />
        <div class="card-body">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-circle me-1"></i>
                    <strong>Vui lòng kiểm tra lại dữ liệu:</strong>
                    <ul class="mb-0 mt-1">
                        @foreach (var state in ViewData.ModelState)
                        {
                            @foreach (var error in state.Value.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            }
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Tên khách hàng:</label>
                    <input type="text" class="form-control" name="CustomerName" value="@Model?.CustomerName" placeholder="Họ và tên khách hàng" autofocus required>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Tên giao dịch:</label>
                    <input type="text" class="form-control" name="ContactName" value="@Model?.ContactName" placeholder="Tên giao dịch">
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Điện thoại:</label>
                    <input type="tel" class="form-control" name="Phone" value="@Model?.Phone" placeholder="Số điện thoại di động">
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Email:</label>
                    <input type="email" class="form-control" name="Email" value="@Model?.Email" placeholder="địa_chỉ_email@gmail.com">
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Địa chỉ:</label>
                    <input type="text" class="form-control" name="Address" value="@Model?.Address" placeholder="Số nhà, tên đường...">
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Tỉnh/Thành:</label>
                    <select class="form-select" name="Province">
                        <option value="">-- Chọn Tỉnh/Thành --</option>
                        <option value="Hà Nội" selected="@(Model?.Province == "Hà Nội")">Hà Nội</option>
                        <option value="TP. Hồ Chí Minh" selected="@(Model?.Province == "TP. Hồ Chí Minh")">TP. Hồ Chí Minh</option>
                        <option value="Đà Nẵng" selected="@(Model?.Province == "Đà Nẵng")">Đà Nẵng</option>
                        <option value="Cần Thơ" selected="@(Model?.Province == "Cần Thơ")">Cần Thơ</option>
                    </select>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold d-block">Trạng thái:</label>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="IsLocked" id="active" value="false" @(Model?.IsLocked != true ? "checked" : "")>
                    <label class="form-check-label text-success" for="active">Đang hoạt động</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="IsLocked" id="locked" value="true" @(Model?.IsLocked == true ? "checked" : "")>
                    <label class="form-check-label text-danger" for="locked">Bị khóa</label>
                </div>
            </div>
        </div>

        <div class="card-footer text-end">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> Lưu dữ liệu
            </button>
            <a href="/Customer" class="btn btn-secondary border">Quay lại</a>
        </div>
    </form>
</div>