@model SV22T1020796.Models.HR.Employee
@{
    ViewBag.Title = "Chỉnh sửa nhân viên";
    string photoSrc = !string.IsNullOrEmpty(Model?.Photo) ? $"~/images/employees/{Model.Photo}" : "~/images/employees/no-photo.png";
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-person-badge me-2"></i>
                    Thông tin nhân viên
                </h5>
            </div>

            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-circle me-1"></i>
                        <strong>Vui lòng kiểm tra lại dữ liệu:</strong>
                        <ul class="mb-0 mt-1">
                            @foreach (var state in ViewData.ModelState)
                            {
                                @foreach (var error in state.Value.Errors)
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <form id="formEdit" action="~/Employee/Save" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="EmployeeID" value="@Model?.EmployeeID" />
                    <input type="hidden" name="Photo" value="@Model?.Photo" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Họ và tên</label>
                        <div class="col-sm-5">
                            <input type="text"
                                   name="FullName"
                                   class="form-control"
                                   value="@Model?.FullName"
                                   placeholder="Nhập họ và tên" autofocus required />
                        </div>
                        <label class="col-sm-2 col-form-label text-end">Ngày sinh</label>
                        <div class="col-sm-2">
                            <input type="date"
                                   name="BirthDate"
                                   class="form-control"
                                   value="@(Model?.BirthDate?.ToString("yyyy-MM-dd"))" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Địa chỉ</label>
                        <div class="col-sm-9">
                            <textarea class="form-control"
                                      name="Address"
                                      rows="3"
                                      placeholder="Nhập địa chỉ">@Model?.Address</textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Điện thoại</label>
                        <div class="col-sm-2">
                            <input type="tel"
                                   name="Phone"
                                   class="form-control"
                                   value="@Model?.Phone"
                                   placeholder="Nhập số điện thoại" />
                        </div>
                        <label class="col-sm-1 col-form-label text-end">Email</label>
                        <div class="col-sm-6">
                            <input type="email"
                                   name="Email"
                                   class="form-control"
                                   value="@Model?.Email"
                                   placeholder="Nhập email" required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="file"
                                   name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="@photoSrc"
                                     class="img-thumbnail"
                                     style="max-height: 150px;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mật khẩu</label>
                        <div class="col-sm-9">
                            <input type="password" 
                                   name="Password" 
                                   class="form-control" 
                                   value="@Model?.Password" 
                                   placeholder="Nhập mật khẩu" @(Model?.EmployeeID == 0 ? "required" : "") />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Quyền hạn</label>
                        <div class="col-sm-9">
                            <div class="d-flex gap-4 mt-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="roles" value="admin" id="roleAdmin" 
                                           @(Model?.RoleNames != null && Model.RoleNames.Split(',').Contains("admin") ? "checked" : "")>
                                    <label class="form-check-label" for="roleAdmin">Quản trị (Admin)</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="roles" value="employee" id="roleEmployee"
                                           @(Model?.RoleNames != null && Model.RoleNames.Split(',').Contains("employee") ? "checked" : "")>
                                    <label class="form-check-label" for="roleEmployee">Nhân viên (Employee)</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="IsWorking"
                                       value="true"
                                       id="IsWorking"
                                       @(Model?.IsWorking == true ? "checked" : "") />
                                <label class="form-check-label" for="IsWorking">
                                    Đang làm việc
                                </label>
                            </div>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
