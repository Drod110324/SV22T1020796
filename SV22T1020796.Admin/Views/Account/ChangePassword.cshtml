@{
    ViewBag.Title = "Đổi mật khẩu";
}

<div class="box box-primary">
    <div class="box-body">
        <form action="~/Account/ChangePassword" method="post" class="form-horizontal">
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="col-md-6 offset-md-3">
                    <div class="form-group mb-3">
                        <label for="oldPassword" class="control-label">Mật khẩu hiện tại:</label>
                        <input type="password" class="form-control" name="oldPassword" autofocus autocomplete="current-password" />
                    </div>

                    <div class="form-group mb-3">
                        <label for="newPassword" class="control-label">Mật khẩu mới:</label>
                        <input type="password" class="form-control" name="newPassword" autocomplete="new-password" />
                    </div>

                    <div class="form-group mb-3">
                        <label for="confirmPassword" class="control-label">Xác nhận mật khẩu mới:</label>
                        <input type="password" class="form-control" name="confirmPassword" autocomplete="new-password" />
                    </div>

                    @Html.ValidationMessage("Error", new { @class = "text-danger d-block mb-3" })

                    <div class="form-group text-center">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Đổi mật khẩu
                        </button>
                        <a href="~/" class="btn btn-secondary">
                            Bỏ qua
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
