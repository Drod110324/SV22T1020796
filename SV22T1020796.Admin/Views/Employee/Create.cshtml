@model SV22T1020796.Models.HR.Employee
@{
    ViewBag.Title = "Thêm nhân viên mới";
}
@section PageToolBar {
    <button type="submit" form="formCreate" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu nhân viên
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card card-primary card-outline shadow-sm">
    <div class="card-header">
        <h3 class="card-title fw-bold text-primary">
            <i class="bi bi-person-add"></i> Thêm nhân viên mới
        </h3>
    </div>

    <div class="card-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-circle me-1"></i>
                <strong>Vui lòng kiểm tra lại dữ liệu:</strong>
                <ul class="mb-0 mt-1">
                    @foreach (var state in ViewData.ModelState)
                    {
                        @foreach (var error in state.Value.Errors)
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    }
                </ul>
            </div>
        }

        <form id="formCreate" action="~/Employee/Save" method="post" enctype="multipart/form-data">
            <input type="hidden" name="EmployeeID" value="@Model?.EmployeeID" />

            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ và tên nhân viên:</label>
                        <input type="text" class="form-control" name="FullName"
                               value="@Model?.FullName"
                               placeholder="Nhập họ và tên..." autofocus required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Email:</label>
                            <input type="email" class="form-control" name="Email"
                                   value="@Model?.Email"
                                   placeholder="Địa chỉ email..." required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Ngày sinh:</label>
                            <input type="date" class="form-control" name="BirthDate"
                                   value="@(Model?.BirthDate?.ToString("yyyy-MM-dd"))">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Điện thoại:</label>
                            <input type="tel" class="form-control" name="Phone"
                                   value="@Model?.Phone"
                                   placeholder="Số điện thoại...">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Trạng thái:</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox"
                                       name="IsWorking" value="true" id="IsWorking"
                                       @(Model?.IsWorking == true ? "checked" : "") />
                                <label class="form-check-label" for="IsWorking">
                                    Đang làm việc
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Địa chỉ:</label>
                        <input type="text" class="form-control" name="Address"
                               value="@Model?.Address"
                               placeholder="Nhập địa chỉ...">
                    </div>
                </div>
                <div class="col-md-4 text-center border-start">
                    <label class="form-label fw-bold d-block text-start ps-3">Ảnh đại diện:</label>
                    <div class="mb-3">
                        <img id="PhotoPreview" src="~/images/employees/no-photo.png"
                             class="img-thumbnail rounded-circle" style="width: 180px; height: 180px; object-fit: cover;">
                    </div>
                    <input type="file" class="form-control form-control-sm" name="uploadPhoto" accept="image/*"
                           onchange="document.getElementById('PhotoPreview').src = window.URL.createObjectURL(this.files[0])">
                </div>
            </div>
        </form>
    </div>
</div>