@model SV22T1020796.Models.Partner.Supplier
@{
    ViewBag.Title = "Thêm nhà cung cấp";
    var provinces = ViewBag.Provinces as List<SV22T1020796.Models.DataDictionary.Province> ?? new List<SV22T1020796.Models.DataDictionary.Province>();
}
@section PageToolBar {
    <button type="submit" form="formCreate" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Supplier" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0 fw-bold text-primary">
                    <i class="bi bi-building-fill-add me-2"></i>
                    Thông tin nhà cung cấp
                </h5>
            </div>

            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-circle me-1"></i>
                        <strong>Vui lòng kiểm tra lại dữ liệu:</strong>
                        <ul class="mb-0 mt-1">
                            @foreach (var state in ViewData.ModelState)
                            {
                                @foreach (var error in state.Value.Errors)
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <form id="formCreate" action="~/Supplier/Save" method="post">
                    <input type="hidden" name="SupplierID" value="@Model?.SupplierID" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tên nhà cung cấp:</label>
                            <input type="text" class="form-control" name="SupplierName"
                                   value="@Model?.SupplierName"
                                   placeholder="Nhập tên nhà cung cấp..." autofocus required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tên giao dịch:</label>
                            <input type="text" class="form-control" name="ContactName"
                                   value="@Model?.ContactName"
                                   placeholder="Tên giao dịch hoặc người đại diện">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Điện thoại:</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                <input type="tel" class="form-control" name="Phone"
                                       value="@Model?.Phone"
                                       placeholder="Số điện thoại...">
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Email:</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input type="email" class="form-control" name="Email"
                                       value="@Model?.Email"
                                       placeholder="Địa chỉ email...">
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Địa chỉ:</label>
                        <input type="text" class="form-control" name="Address"
                               value="@Model?.Address"
                               placeholder="Số nhà, tên đường...">
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Tỉnh/Thành:</label>
                        <select class="form-select" name="Province">
                            <option value="">-- Chọn Tỉnh/Thành --</option>
                            @foreach (var p in provinces)
                            {
                                <option value="@p.ProvinceName"
                                        selected="@(Model?.Province == p.ProvinceName)">
                                    @p.ProvinceName
                                </option>
                            }
                        </select>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>