@model List<SV22T1020796.Models.Sales.OrderDetailViewInfo>
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}

<div class="container py-5">
    <h2 class="fw-bold mb-4">Giỏ hàng của bạn</h2>

    @if (Model.Count > 0)
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4 py-3">Sản phẩm</th>
                                        <th class="text-center py-3">Giá</th>
                                        <th class="text-center py-3">Số lượng</th>
                                        <th class="text-end py-3 pe-4">Tổng tiền</th>
                                        <th class="py-3"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 py-4">
                                                <div class="d-flex align-items-center">
                                                    <img src="http://localhost:5036/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)" 
                                                         class="rounded-3 me-3" style="width: 60px; height: 60px; object-fit: cover;"
                                                         onerror="this.src='/images/products/nophoto.png'">
                                                    <div>
                                                        <h6 class="mb-0 fw-bold">@item.ProductName</h6>
                                                        <small class="text-muted">Đơn vị: @item.Unit</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center">@item.SalePrice.ToString("N0") đ</td>
                                            <td class="text-center">
                                                <div class="d-inline-flex border rounded-2">
                                                    <button class="btn btn-sm btn-link py-1 text-dark text-decoration-none" onclick="updateQuantity(@item.ProductID, -1)">-</button>
                                                    <span class="px-3 py-1 bg-white">@item.Quantity</span>
                                                    <button class="btn btn-sm btn-link py-1 text-dark text-decoration-none" onclick="updateQuantity(@item.ProductID, 1)">+</button>
                                                </div>
                                            </td>
                                            <td class="text-end fw-bold pe-4">@((item.SalePrice * item.Quantity).ToString("N0")) đ</td>
                                            <td class="pe-3">
                                                <button class="btn btn-link text-danger p-0" onclick="removeFromCart(@item.ProductID)">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 py-3 px-4 text-end">
                        <button class="btn btn-outline-danger rounded-pill px-4" onclick="clearCart()">
                            <i class="fa-solid fa-trash-can me-2"></i>Xóa sạch giỏ hàng
                        </button>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 100px;">
                    <h5 class="fw-bold mb-4">Tóm tắt đơn hàng</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tạm tính</span>
                        <span class="fw-bold">@Model.Sum(i => i.SalePrice * i.Quantity).ToString("N0") đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="text-muted">Phí vận chuyển</span>
                        <span class="fw-bold">Miễn phí</span>
                    </div>
                    <hr class="mb-4">
                    <div class="d-flex justify-content-between mb-5">
                        <h5 class="fw-bold">Tổng thanh toán</h5>
                        <h5 class="fw-bold text-primary">@Model.Sum(i => i.SalePrice * i.Quantity).ToString("N0") đ</h5>
                    </div>
                    <a href="~/Order/Checkout" class="btn btn-primary w-100 py-3 rounded-3 fw-bold shadow-lg">Tiến tới đặt hàng</a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fa-solid fa-cart-shopping fs-1 text-muted opacity-25 mb-4"></i>
            <h4 class="fw-bold mb-3">Giỏ hàng của bạn đang trống</h4>
            <p class="text-muted mb-4">Hãy tiếp tục khám phá và chọn cho mình những sản phẩm ưng ý nhé!</p>
            <a href="~/Home/Index" class="btn btn-primary px-5 py-3 rounded-pill fw-bold">Quay lại trang sản phẩm</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function updateQuantity(productID, delta) {
            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { productID: productID, quantity: delta },
                success: function (response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Lỗi',
                            text: response.message,
                            confirmButtonColor: '#3b82f6',
                            confirmButtonText: 'Đóng'
                        });
                    }
                }
            });
        }

        function removeFromCart(productID) {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: "Bạn có chắc chắn muốn xóa sản phẩm này khỏi giỏ hàng?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Xóa ngay',
                cancelButtonText: 'Hủy bỏ',
                reverseButtons: true,
                customClass: {
                    container: 'rounded-4',
                    popup: 'rounded-4',
                    confirmButton: 'rounded-3 fw-bold px-4 py-2',
                    cancelButton: 'rounded-3 fw-bold px-4 py-2'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Cart/RemoveFromCart',
                        type: 'POST',
                        data: { productID: productID },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    title: 'Đã xóa!',
                                    text: 'Sản phẩm đã được xóa khỏi giỏ hàng.',
                                    icon: 'success',
                                    showConfirmButton: false,
                                    timer: 1500
                                }).then(() => {
                                    location.reload();
                                });
                            }
                        }
                    });
                }
            });
        }
        function clearCart() {
            Swal.fire({
                title: 'Xóa toàn bộ giỏ hàng?',
                text: "Bạn có chắc chắn muốn xóa tất cả sản phẩm đang có trong giỏ hàng?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Xóa sạch',
                cancelButtonText: 'Hủy bỏ',
                reverseButtons: true,
                customClass: {
                    container: 'rounded-4',
                    popup: 'rounded-4',
                    confirmButton: 'rounded-3 fw-bold px-4 py-2',
                    cancelButton: 'rounded-3 fw-bold px-4 py-2'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Cart/ClearCart',
                        type: 'POST',
                        success: function (response) {
                            if (response.success) {
                                location.reload();
                            }
                        }
                    });
                }
            });
        }
    </script>
}
