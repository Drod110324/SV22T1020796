@model SV22T1020796.Models.Sales.OrderViewInfo
@using SV22T1020796.Models.Sales
@{
    ViewBag.Title = "Chi tiết đơn hàng";
    var details = ViewBag.Details as IEnumerable<SV22T1020796.Models.Sales.OrderDetailViewInfo>;
}

@section PageToolBar {
    <div class="btn-group">
        @if (Model.Status == SV22T1020796.Models.Sales.OrderStatusEnum.New)
        {
            <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-gear me-1"></i> Xử lý đơn hàng
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item order-action" href="~/Order/Accept/@Model.OrderID" data-msg="Xác nhận duyệt đơn hàng này?">Duyệt đơn hàng</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger order-action" href="~/Order/Reject/@Model.OrderID" data-msg="Xác nhận từ chối đơn hàng này?">Từ chối đơn hàng</a></li>
                <li><a class="dropdown-item text-danger order-action" href="~/Order/Cancel/@Model.OrderID" data-msg="Xác nhận hủy đơn hàng này?">Hủy đơn hàng</a></li>
            </ul>
        }
        else if (Model.Status == SV22T1020796.Models.Sales.OrderStatusEnum.Accepted)
        {
            <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-gear me-1"></i> Xử lý đơn hàng
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item open-modal" href="~/Order/Shipping/@Model.OrderID">Chuyển giao hàng</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger order-action" href="~/Order/Cancel/@Model.OrderID" data-msg="Xác nhận hủy đơn hàng này?">Hủy đơn hàng</a></li>
            </ul>
        }
        else if (Model.Status == SV22T1020796.Models.Sales.OrderStatusEnum.Shipping)
        {
            <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-gear me-1"></i> Xử lý đơn hàng
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item order-action" href="~/Order/Finish/@Model.OrderID" data-msg="Xác nhận đã hoàn tất đơn hàng này?">Hoàn tất đơn hàng</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger order-action" href="~/Order/Cancel/@Model.OrderID" data-msg="Xác nhận hủy đơn hàng này?">Hủy đơn hàng</a></li>
            </ul>
        }
    </div>

    @if (Model.Status == SV22T1020796.Models.Sales.OrderStatusEnum.Cancelled || 
         Model.Status == SV22T1020796.Models.Sales.OrderStatusEnum.Rejected ||
         Model.Status == SV22T1020796.Models.Sales.OrderStatusEnum.New)
    {
        <a href="~/Order/Delete/@Model.OrderID" class="btn btn-danger ms-1 order-action" data-msg="Xác nhận xóa vĩnh viễn đơn hàng này?">
            <i class="bi bi-trash"></i> Xóa
        </a>
    }

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<!-- TRẠNG THÁI ĐƠN HÀNG -->
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger mb-3">@TempData["ErrorMessage"]</div>
}

<div class="alert alert-info d-flex align-items-center mb-3">
    <i class="bi bi-info-circle-fill fs-4 me-2"></i>
    <div>
        <strong>Trạng thái đơn hàng:</strong>
        <span class="badge @(Model.Status.GetColorClass())">@Model.StatusDescription</span>
        @if (Model.FinishedTime.HasValue)
        {
            <span> lúc <b>@Model.FinishedTime.Value.ToString("dd/MM/yyyy HH:mm")</b></span>
        }
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <!-- THÔNG TIN ĐƠN HÀNG -->
        <div class="card card-primary card-outline mb-3">
            <div class="card-header">
                <h5 class="card-title mb-0">Thông tin đơn hàng</h5>
            </div>
            <div class="card-body">
                <p class="mb-1"><strong>Mã đơn hàng:</strong> @Model.OrderID</p>
                <p class="mb-1"><strong>Ngày lập:</strong> @Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</p>
                <p class="mb-1"><strong>Nhân viên phụ trách:</strong> @Model.EmployeeName</p>
                <p class="mb-0"><strong>Ngày nhận đơn:</strong> @Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- THÔNG TIN KHÁCH HÀNG -->
        <div class="card card-info card-outline mb-3">
            <div class="card-header">
                <h5 class="card-title mb-0">Thông tin khách hàng</h5>
            </div>
            <div class="card-body">
                <p class="mb-1"><strong>Khách hàng:</strong> @Model.CustomerName</p>
                <p class="mb-1"><strong>Điện thoại:</strong> @Model.CustomerPhone</p>
                <p class="mb-1"><strong>Email:</strong> @Model.CustomerEmail</p>
                <p class="mb-0"><strong>Địa chỉ:</strong> @Model.CustomerAddress</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- THÔNG TIN GIAO HÀNG -->
        <div class="card card-success card-outline mb-3">
            <div class="card-header">
                <h5 class="card-title mb-0">Thông tin giao hàng</h5>
            </div>
            <div class="card-body">
                <p class="mb-1"><strong>Người giao hàng:</strong> @Model.ShipperName</p>
                <p class="mb-1"><strong>Điện thoại:</strong> @Model.ShipperPhone</p>
                <p class="mb-1"><strong>Địa chỉ giao:</strong> @Model.DeliveryAddress</p>
                <p class="mb-0"><strong>Tỉnh / Thành:</strong> @Model.DeliveryProvince</p>
            </div>
        </div>
    </div>
</div>

<!-- DANH SÁCH MẶT HÀNG -->
<div class="card card-secondary card-outline">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Danh sách mặt hàng</h5>
    </div>
    <div class="card-body table-responsive p-0">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-secondary text-center">
                <tr>
                    <th style="width:50px">STT</th>
                    <th>Tên hàng</th>
                    <th style="width:100px">ĐVT</th>
                    <th style="width:100px">Số lượng</th>
                    <th style="width:150px">Giá</th>
                    <th style="width:150px">Thành tiền</th>
                    <th style="width:100px"></th>
                </tr>
            </thead>
            <tbody>
                @if (details != null && details.Any())
                {
                    int i = 0;
                    foreach (var item in details)
                    {
                        i++;
                        <tr>
                            <td class="text-center">@i</td>
                            <td>@item.ProductName</td>
                            <td class="text-center">@item.Unit</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                            <td class="text-end fw-bold">@item.TotalPrice.ToString("N0")</td>
                            <td class="text-center">
                                @if (Model.Status == SV22T1020796.Models.Sales.OrderStatusEnum.New)
                                {
                                    <a href="~/Order/EditCartItem/@Model.OrderID?productId=@item.ProductID" class="btn btn-sm btn-outline-primary open-modal">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="~/Order/DeleteCartItem/@Model.OrderID?productId=@item.ProductID" class="btn btn-sm btn-outline-danger order-action" data-msg="Xóa mặt hàng này khỏi đơn hàng?">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng:</th>
                    <th class="text-end text-danger fs-5">@Model.DetailsTotalValue.ToString("N0")</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .card-body p { border-bottom: 1px dotted #dee2e6; padding-bottom: 5px; }
        .card-body p:last-child { border-bottom: none; }
    </style>
}
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            document.querySelectorAll(".order-action").forEach(el => {
                el.addEventListener("click", function(e) {
                    e.preventDefault();
                    const url = this.getAttribute("href");
                    const msg = this.dataset.msg;

                    Swal.fire({
                        title: 'Xác nhận',
                        text: msg,
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonColor: '#3085d6',
                        cancelButtonColor: '#d33',
                        confirmButtonText: 'Đồng ý',
                        cancelButtonText: 'Hủy bỏ'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = url;
                        }
                    });
                });
            });
        });
    </script>
}
