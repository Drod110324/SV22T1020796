@model SV22T1020796.Models.Partner.Customer
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="container py-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 text-center mb-4">
                <div class="position-relative d-inline-block mx-auto mb-4">
                    <img src="https://ui-avatars.com/api/?name=@Model.CustomerName&background=random&size=128" 
                         class="rounded-circle shadow" 
                         alt="Avatar">
                    <div class="position-absolute bottom-0 end-0 bg-primary rounded-circle p-2 text-white border border-4 border-white">
                        <i class="fa-solid fa-camera small"></i>
                    </div>
                </div>
                <h4 class="fw-bold">@Model.CustomerName</h4>
                <p class="text-muted small">@Model.Email</p>
                <hr>
                <div class="list-group list-group-flush text-start">
                    <button class="list-group-item list-group-item-action border-0 px-0 d-flex align-items-center active bg-transparent text-primary" data-bs-toggle="tab" data-bs-target="#tabProfile">
                        <i class="fa-solid fa-user-gear me-3"></i>Thông tin cá nhân
                    </button>
                    <button class="list-group-item list-group-item-action border-0 px-0 d-flex align-items-center bg-transparent text-muted" data-bs-toggle="tab" data-bs-target="#tabPassword">
                        <i class="fa-solid fa-key me-3"></i>Đổi mật khẩu
                    </button>
                    <a href="~/Order" class="list-group-item list-group-item-action border-0 px-0 d-flex align-items-center bg-transparent text-muted">
                        <i class="fa-solid fa-history me-3"></i>Lịch sử mua hàng
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="tab-content">
                <!-- Tab Profile Info -->
                <div class="tab-pane fade show active" id="tabProfile">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-4">Thông tin của bạn</h5>
                        
                        @if (ViewBag.SuccessMessage != null)
                        {
                            <div class="alert alert-success border-0 small mb-4" style="border-radius: 1rem;">
                                <i class="fa-solid fa-circle-check me-2"></i>@ViewBag.SuccessMessage
                            </div>
                        }

                        @if (ViewBag.ErrorMessage != null)
                        {
                            <div class="alert alert-danger border-0 small mb-4" style="border-radius: 1rem;">
                                <i class="fa-solid fa-circle-exclamation me-2"></i>@ViewBag.ErrorMessage
                            </div>
                        }

                        <form method="post" action="/Account/Profile">
                            <input type="hidden" name="CustomerID" value="@Model.CustomerID">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label class="form-label text-muted small fw-bold">Họ và tên</label>
                                    <input type="text" name="CustomerName" class="form-control" value="@Model.CustomerName" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-bold">Số điện thoại</label>
                                    <input type="tel" name="Phone" class="form-control" value="@Model.Phone" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-bold">Email</label>
                                    <input type="email" name="Email" class="form-control bg-light" value="@Model.Email" readonly disabled>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-bold">Tỉnh/Thành</label>
                                    <select name="Province" class="form-select" required>
                                        @foreach (var province in await SV22T1020796.BusinessLayers.DictionaryDataService.ListProvincesAsync())
                                        {
                                            <option value="@province.ProvinceName" selected="@(Model.Province == province.ProvinceName)">@province.ProvinceName</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label text-muted small fw-bold">Địa chỉ</label>
                                    <textarea name="Address" class="form-control" rows="3">@Model.Address</textarea>
                                </div>
                            </div>
                            <div class="mt-4">
                                <button type="submit" class="btn btn-primary rounded-3 px-4 fw-bold">Lưu thay đổi</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Tab Password Change -->
                <div class="tab-pane fade" id="tabPassword">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-4">Đổi mật khẩu</h5>

                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-danger border-0 small mb-4" style="border-radius: 1rem;">
                                <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["ErrorMessage"]
                            </div>
                        }

                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success border-0 small mb-4" style="border-radius: 1rem;">
                                <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
                            </div>
                        }

                        <form method="post" action="/Account/ChangePassword">
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">Mật khẩu cũ</label>
                                <input type="password" name="oldPassword" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">Mật khẩu mới</label>
                                <input type="password" name="newPassword" class="form-control" required minlength="6">
                            </div>
                            <div class="mb-4">
                                <label class="form-label text-muted small fw-bold">Xác nhận mật khẩu mới</label>
                                <input type="password" name="confirmPassword" class="form-control" required minlength="6">
                            </div>
                            <div>
                                <button type="submit" class="btn btn-primary rounded-3 px-4 fw-bold">Cập nhật mật khẩu</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
