@using SV22T1020796.BusinessLayers
@model SV22T1020796.Models.Common.PagedResult<SV22T1020796.Models.Catalog.Product>
@{
    ViewData["Title"] = "Tất cả sản phẩm - NHV Shop";
}

<div class="bg-light py-4 border-bottom mb-4">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="~/" class="text-decoration-none"><i class="fa-solid fa-house me-1"></i>Trang chủ</a></li>
                <li class="breadcrumb-item active" aria-current="page">Sản phẩm</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container mb-5">
    <div class="row">
        <!-- Sidebar Filter -->
        <div class="col-lg-3 mb-4 mb-lg-0">
            <div class="card border-0 shadow-sm rounded-4 position-sticky" style="top: 100px;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="fw-bold"><i class="fa-solid fa-filter text-primary me-2"></i>Bộ lọc tìm kiếm</h5>
                </div>
                <div class="card-body">
                    <form action="~/Product/Index" method="get" id="formSearch">
                        <!-- Tìm kiếm -->
                        <div class="mb-4">
                            <label class="form-label text-muted small fw-bold">Tìm kiếm từ khóa</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-light rounded-start-3">
                                    <i class="fa-solid fa-magnifying-glass text-muted"></i>
                                </span>
                                <input type="text" name="searchValue" class="form-control border-0 bg-light rounded-end-3" 
                                       placeholder="Tên sản phẩm..." value="@ViewBag.SearchValue">
                            </div>
                        </div>

                        <!-- Danh mục -->
                        <div class="mb-4">
                            <label class="form-label text-muted small fw-bold">Danh mục sản phẩm</label>
                            <select name="categoryID" class="form-select border-0 bg-light rounded-3">
                                <option value="0">Tất cả danh mục</option>
                                @foreach (var cat in (await CatalogDataService.ListCategoriesAsync(new SV22T1020796.Models.Common.PaginationSearchInput { Page = 1, PageSize = 100, SearchValue = "" })).DataItems)
                                {
                                    <option value="@cat.CategoryID" selected="@(ViewBag.CategoryID?.ToString() == cat.CategoryID.ToString())">@cat.CategoryName</option>
                                }
                            </select>
                        </div>

                        <!-- Khoảng giá -->
                        <div class="mb-4">
                            <label class="form-label text-muted small fw-bold">Khoảng giá</label>
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <input type="number" id="minPrice" name="minPrice" class="form-control border-0 bg-light rounded-3" 
                                           placeholder="Từ" value="@(ViewBag.MinPrice > 0 ? ViewBag.MinPrice : "")">
                                </div>
                                <div class="col-6">
                                    <input type="number" id="maxPrice" name="maxPrice" class="form-control border-0 bg-light rounded-3" 
                                           placeholder="Đến" value="@(ViewBag.MaxPrice > 0 ? ViewBag.MaxPrice : "")">
                                </div>
                            </div>
                            <!-- Nút chọn nhanh -->
                            <div class="d-flex flex-wrap gap-2 mt-2">
                                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" onclick="setQuickPrice(0, 1000000)">Dưới 1 triệu</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" onclick="setQuickPrice(1000000, 5000000)">1 - 5 triệu</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" onclick="setQuickPrice(5000000, 10000000)">5 - 10 triệu</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" onclick="setQuickPrice(10000000, 20000000)">10 - 20 triệu</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" onclick="setQuickPrice(20000000, 0)">Trên 20 triệu</button>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 rounded-3 py-2 shadow-sm fw-bold">
                            <i class="fa-solid fa-check me-2"></i>Áp dụng bộ lọc
                        </button>
                        <a href="~/Product/Index" class="btn btn-light w-100 rounded-3 py-2 mt-2 fw-bold text-muted">
                            Xóa bộ lọc
                        </a>
                    </form>
                </div>
            </div>
        </div>

        <!-- Product Grid -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="mb-0 fw-bold">Tất cả sản phẩm</h4>
                <p class="text-muted mb-0 small">Hiển thị @Model.DataItems.Count() kết quả</p>
            </div>

            @if (Model.DataItems.Any())
            {
                <div class="row g-4">
                    @foreach (var item in Model.DataItems)
                    {
                        <div class="col-6 col-md-4">
                            <div class="product-card" onclick="location.href='@Url.Content("~/Product/Details/" + item.ProductID)'">
                                <div class="product-image-container">
                                    <img src="@(string.IsNullOrEmpty(item.Photo) ? "https://via.placeholder.com/300x300?text=No+Photo" : "http://localhost:5036/images/products/" + item.Photo)" 
                                         class="product-image" alt="" 
                                         onerror="this.src='http://localhost:5036/images/products/nophoto.png'">
                                </div>
                                <div class="product-info d-flex flex-column h-100">
                                    <h3 class="product-title mb-auto">@item.ProductName</h3>
                                    <div class="mt-3">
                                        <div class="product-price mb-3">@item.Price.ToString("N0") <small>đ</small></div>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-outline-primary btn-icon flex-shrink-0" 
                                                    onclick="event.stopPropagation(); addToCart(@item.ProductID)" title="Thêm vào giỏ">
                                                <i class="fa-solid fa-cart-plus"></i>
                                            </button>
                                            <button class="btn btn-primary flex-grow-1 rounded-3 fw-bold" 
                                                    onclick="event.stopPropagation(); buyNow(@item.ProductID)">
                                                Mua ngay
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.PageCount > 1)
                {
                    <div class="d-flex justify-content-center mt-5">
                        <nav aria-label="Page navigation">
                            <ul class="pagination pagination-md shadow-sm border-0 gap-1">
                                <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                                    <a class="page-link border rounded-circle text-dark @(Model.Page == 1 ? "bg-light" : "")" 
                                       href="~/Product/Index?page=@(Model.Page - 1)&categoryID=@ViewBag.CategoryID&searchValue=@ViewBag.SearchValue&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice"
                                       style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                        <i class="fa-solid fa-chevron-left small"></i>
                                    </a>
                                </li>

                                @{
                                    int delta = 2;
                                    int left = Model.Page - delta;
                                    int right = Model.Page + delta;
                                    
                                    if (left > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link border rounded-circle text-dark" href="~/Product/Index?page=1&categoryID=@ViewBag.CategoryID&searchValue=@ViewBag.SearchValue&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">1</a>
                                        </li>
                                        if (left > 2)
                                        {
                                            <li class="page-item disabled"><span class="page-link border-0 bg-transparent">...</span></li>
                                        }
                                    }

                                    for (int i = Math.Max(1, left); i <= Math.Min(Model.PageCount, right); i++)
                                    {
                                        <li class="page-item @(i == Model.Page ? "active" : "")">
                                            <a class="page-link border rounded-circle @(i == Model.Page ? "bg-primary border-primary text-white" : "text-dark bg-white")" 
                                               href="~/Product/Index?page=@i&categoryID=@ViewBag.CategoryID&searchValue=@ViewBag.SearchValue&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice"
                                               style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">@i</a>
                                        </li>
                                    }

                                    if (right < Model.PageCount)
                                    {
                                        if (right < Model.PageCount - 1)
                                        {
                                            <li class="page-item disabled"><span class="page-link border-0 bg-transparent">...</span></li>
                                        }
                                        <li class="page-item">
                                            <a class="page-link border rounded-circle text-dark" href="~/Product/Index?page=@Model.PageCount&categoryID=@ViewBag.CategoryID&searchValue=@ViewBag.SearchValue&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">@Model.PageCount</a>
                                        </li>
                                    }
                                }

                                <li class="page-item @(Model.Page == Model.PageCount ? "disabled" : "")">
                                    <a class="page-link border rounded-circle text-dark @(Model.Page == Model.PageCount ? "bg-light" : "")" 
                                       href="~/Product/Index?page=@(Model.Page + 1)&categoryID=@ViewBag.CategoryID&searchValue=@ViewBag.SearchValue&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice"
                                       style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                        <i class="fa-solid fa-chevron-right small"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5 bg-light rounded-4">
                    <i class="fa-solid fa-box-open fs-1 text-muted mb-3"></i>
                    <h5 class="text-muted">Không tìm thấy sản phẩm nào phù hợp</h5>
                    <p class="text-muted small">Vui lòng thử lại với từ khóa hoặc bộ lọc khác.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function setQuickPrice(min, max) {
            document.getElementById('minPrice').value = min > 0 ? min : '';
            document.getElementById('maxPrice').value = max > 0 ? max : '';
            document.getElementById('formSearch').submit();
        }
        function addToCart(productID) {
            $.ajax({
                url: '@Url.Content("~/Cart/AddToCart")',
                type: 'POST',
                data: { productID: productID, quantity: 1 },
                success: function (response) {
                    if (response.success) {
                        $('.cart-badge').text(response.cartCount);
                        const Toast = Swal.mixin({
                            toast: true,
                            position: 'top',
                            showConfirmButton: false,
                            timer: 3000,
                            timerProgressBar: true
                        })
                        Toast.fire({
                            icon: 'success',
                            title: 'Đã thêm vào giỏ hàng thành công!'
                        })
                    } else {
                        Swal.fire({
                            icon: 'info',
                            title: 'Thông báo',
                            text: response.message,
                            confirmButtonColor: '#3085d6'
                        });
                    }
                }
            });
        }

        function buyNow(productID) {
            $.ajax({
                url: '@Url.Content("~/Cart/AddToCart")',
                type: 'POST',
                data: { productID: productID, quantity: 1 },
                success: function (response) {
                    if (response.success) {
                        window.location.href = '@Url.Content("~/Order/Checkout")';
                    } else {
                        Swal.fire({
                            icon: 'info',
                            title: 'Thông báo',
                            text: response.message,
                            confirmButtonColor: '#3085d6'
                        });
                    }
                }
            });
        }
    </script>
}
