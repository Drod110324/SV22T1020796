@model SV22T1020796.Models.Common.PagedResult<SV22T1020796.Models.Partner.Shipper>
@{
    ViewBag.Title = "Quản lý Người giao hàng";
}
@section PageToolBar {
    <a href="~/Shipper/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-1"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Shipper" method="get">
            <div class="input-group">
                <input type="text"
                       name="searchValue"
                       class="form-control"
                       value="@Model.SearchValue"
                       placeholder="Tên người giao hàng..." autofocus />
                <button type="submit" class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> người giao hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên người giao hàng</th>
                    <th>Điện thoại</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems != null && Model.DataItems.Count > 0)
                {
                    @foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td>@item.ShipperName</td>
                            <td>@item.Phone</td>
                            <td class="text-center text-nowrap">
                                <a href="~/Shipper/Edit/@item.ShipperID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Shipper/Delete/@item.ShipperID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-3">
                            <i class="bi bi-inbox me-1"></i>
                            Không tìm thấy người giao hàng nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">
                @if (Model.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" href="~/Shipper?page=@(Model.Page - 1)&searchValue=@Model.SearchValue">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                }

                @foreach (var pageItem in Model.GetDisplayPages(3))
                {
                    if (pageItem.IsEllipsis)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }
                    else
                    {
                        <li class="page-item @(pageItem.IsCurrent ? "active" : "")">
                            <a class="page-link" href="~/Shipper?page=@pageItem.Page&searchValue=@Model.SearchValue">
                                @pageItem.Page
                            </a>
                        </li>
                    }
                }

                @if (Model.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" href="~/Shipper?page=@(Model.Page + 1)&searchValue=@Model.SearchValue">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </div>
    }
</div>
