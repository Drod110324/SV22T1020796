@model SV22T1020796.Models.Common.PagedResult<SV22T1020796.Models.Sales.OrderViewInfo>
@{
    Layout = null;
}
<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> đơn hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th class="text-center" style="width:70px">Mã ĐH</th>
                    <th>Ngày đặt hàng</th>
                    <th>Tên khách hàng</th>
                    <th>Điện thoại</th>
                    <th>Ngày duyệt</th>
                    <th>Nhân viên xử lý</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td class="text-center">@item.OrderID</td>
                        <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.CustomerName</td>
                        <td>@item.CustomerPhone</td>
                        <td>@item.AcceptTime?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.EmployeeName</td>
                        <td class="text-end fw-bold">@item.TotalValue.ToString("N0")</td>
                        <td class="text-center">
                            @if (item.Status == SV22T1020796.Models.Sales.OrderStatusEnum.New)
                            {
                                <span class="badge bg-warning text-dark">Chờ duyệt</span>
                            }
                            else if (item.Status == SV22T1020796.Models.Sales.OrderStatusEnum.Accepted)
                            {
                                <span class="badge bg-primary text-white">Đã duyệt</span>
                            }
                            else if (item.Status == SV22T1020796.Models.Sales.OrderStatusEnum.Shipping)
                            {
                                <span class="badge bg-info text-dark">Đang giao</span>
                            }
                            else if (item.Status == SV22T1020796.Models.Sales.OrderStatusEnum.Completed)
                            {
                                <span class="badge bg-success text-white">Hoàn tất</span>
                            }
                            else if (item.Status == SV22T1020796.Models.Sales.OrderStatusEnum.Rejected)
                            {
                                <span class="badge bg-danger text-white">Bị từ chối</span>
                            }
                            else if (item.Status == SV22T1020796.Models.Sales.OrderStatusEnum.Cancelled)
                            {
                                <span class="badge bg-secondary text-white">Bị hủy</span>
                            }
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Order/Detail/@item.OrderID" class="btn btn-sm btn-primary">
                                <i class="bi bi-receipt"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                @* Nút Trước *@
                <li class="page-item @(Model.Page > 1 ? "" : "disabled")">
                    <a class="page-link" href="javascript:;"
                       onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page - 1))">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @{
                    int window = 2;
                    int startPage = Math.Max(1, Model.Page - window);
                    int endPage = Math.Min(Model.PageCount, Model.Page + window);
                }
                @if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), 1)">1</a>
                    </li>
                    if (startPage > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }
                @for (int p = startPage; p <= endPage; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @p)">@p</a>
                    </li>
                }
                @if (endPage < Model.PageCount)
                {
                    if (endPage < Model.PageCount - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @Model.PageCount)">@Model.PageCount</a>
                    </li>
                }
                @* Nút Sau *@
                <li class="page-item @(Model.Page < Model.PageCount ? "" : "disabled")">
                    <a class="page-link" href="javascript:;"
                       onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page + 1))">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </div>
    }
</div>

