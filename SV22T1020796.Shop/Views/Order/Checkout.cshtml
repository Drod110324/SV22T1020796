            }

            // Validate Sáŧ Äiáŧn thoášĄi
            var phone = $('input[name="phone"]').val() ? $('input[name="phone"]').val().trim() : "";
            if (!phone) {
                $('#error-phone').text('Vui lÃēng nháš­p sáŧ Äiáŧn thoášĄi');
                $('input[name="phone"]').addClass('is-invalid border-danger');
                isValid = false;
            } else if (!/^\d{10,11}$/.test(phone)) {
