@model SV22T1020796.Models.Common.PagedResult<SV22T1020796.Models.Catalog.Product>
@{
    ViewData["Title"] = "NHV Shop - Thế giới công nghệ";
}

<!-- Hero Section -->
<section class="hero-section text-center">
    <div class="container">
        <h1 class="hero-title">Khám phá công nghệ mới</h1>
        <p class="hero-subtitle">Nâng tầm trải nghiệm của bạn với những sản phẩm hàng đầu từ NHV Shop.</p>
        <a href="#products" class="btn btn-primary btn-lg px-5 py-3 fw-bold border-0 shadow" style="border-radius: 1rem;">Mua ngay</a>
    </div>
</section>

<div class="container mb-5" id="products">
    <!-- Product Grid -->
    <div class="row g-4">
        @foreach (var item in Model.DataItems)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <div class="product-card" onclick="location.href='/Product/Details/@item.ProductID'">
                    <div class="product-image-container">
                        <img src="@(string.IsNullOrEmpty(item.Photo) ? "https://via.placeholder.com/300x300?text=No+Photo" : "http://localhost:5036/images/products/" + item.Photo)" 
                             class="product-image" alt="@item.ProductName" 
                             onerror="this.src='/images/products/nophoto.png'">
                    </div>
                    <div class="product-info d-flex flex-column h-100">
                        <h3 class="product-title mb-auto">@item.ProductName</h3>
                        <div class="mt-3">
                            <div class="product-price mb-3">@item.Price.ToString("N0") <small>đ</small></div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-primary btn-icon flex-shrink-0" 
                                        onclick="event.stopPropagation(); addToCart(@item.ProductID)" title="Thêm vào giỏ">
                                    <i class="fa-solid fa-cart-plus"></i>
                                </button>
                                <button class="btn btn-primary flex-grow-1 rounded-3 fw-bold" 
                                        onclick="event.stopPropagation(); buyNow(@item.ProductID)">
                                    Mua ngay
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.PageCount > 1)
    {
        <div class="d-flex justify-content-center mt-5">
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-md shadow-sm border-0 gap-1">
                            <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                                <a class="page-link border rounded-circle text-dark @(Model.Page == 1 ? "bg-light" : "")" 
                                   href="~/Home/Index?page=@(Model.Page - 1)&categoryID=@ViewBag.CategoryID&searchValue=@ViewBag.SearchValue&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice"
                                   style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fa-solid fa-chevron-left small"></i>
                                </a>
                            </li>

                            @{
                                int delta = 2;
                                int left = Model.Page - delta;
                                int right = Model.Page + delta;
                                
                                if (left > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link border rounded-circle text-dark" href="~/Home/Index?page=1&categoryID=@ViewBag.CategoryID&searchValue=@ViewBag.SearchValue&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">1</a>
                                    </li>
                                    if (left > 2)
                                    {
                                        <li class="page-item disabled"><span class="page-link border-0 bg-transparent">...</span></li>
                                    }
                                }

                                for (int i = Math.Max(1, left); i <= Math.Min(Model.PageCount, right); i++)
                                {
                                    <li class="page-item @(i == Model.Page ? "active" : "")">
                                        <a class="page-link border rounded-circle @(i == Model.Page ? "bg-primary border-primary text-white" : "text-dark bg-white")" 
                                           href="~/Home/Index?page=@i&categoryID=@ViewBag.CategoryID&searchValue=@ViewBag.SearchValue&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice"
                                           style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">@i</a>
                                    </li>
                                }

                                if (right < Model.PageCount)
                                {
                                    if (right < Model.PageCount - 1)
                                    {
                                        <li class="page-item disabled"><span class="page-link border-0 bg-transparent">...</span></li>
                                    }
                                    <li class="page-item">
                                        <a class="page-link border rounded-circle text-dark" href="~/Home/Index?page=@Model.PageCount&categoryID=@ViewBag.CategoryID&searchValue=@ViewBag.SearchValue&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">@Model.PageCount</a>
                                    </li>
                                }
                            }

                            <li class="page-item @(Model.Page == Model.PageCount ? "disabled" : "")">
                                <a class="page-link border rounded-circle text-dark @(Model.Page == Model.PageCount ? "bg-light" : "")" 
                                   href="~/Home/Index?page=@(Model.Page + 1)&categoryID=@ViewBag.CategoryID&searchValue=@ViewBag.SearchValue&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice"
                                   style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fa-solid fa-chevron-right small"></i>
                                </a>
                            </li>
                </ul>
            </nav>
        </div>
    }
</div>

@section Scripts {
    <script>
        function addToCart(productID) {
            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { productID: productID, quantity: 1 },
                success: function (response) {
                    if (response.success) {
                        $('.cart-badge').text(response.cartCount);
                        // Show premium toast notification
                        const Toast = Swal.mixin({
                            toast: true,
                            position: 'top',
                            showConfirmButton: false,
                            timer: 3000,
                            timerProgressBar: true
                        })
                        Toast.fire({
                            icon: 'success',
                            title: 'Đã thêm vào giỏ hàng thành công!'
                        })
                    } else {
                        Swal.fire({
                            icon: 'info',
                            title: 'Thông báo',
                            text: response.message,
                            confirmButtonColor: '#3085d6'
                        });
                    }
                }
            });
        }

        function buyNow(productID) {
            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { productID: productID, quantity: 1 },
                success: function (response) {
                    if (response.success) {
                        window.location.href = '/Order/Checkout';
                    } else {
                        Swal.fire({
                            icon: 'info',
                            title: 'Thông báo',
                            text: response.message,
                            confirmButtonColor: '#3085d6'
                        });
                    }
                }
            });
        }
    </script>
}
